# arising from, out of, or in connection with the script or the use of this script.
#
# Usage:
#   ./gitsr <submodule_path>
#

set -e

SUBMODULE="$1"

if [ -z "$SUBMODULE" ]; then
    echo "gitsr - safely remove a Git submodule."
    echo "Usage: $0 <submodule_path>"
    exit 1
fi

# Check if submodule exists in .gitmodules
if ! grep -Fq "[submodule \"$SUBMODULE\"]" .gitmodules; then
    echo "Error: Submodule '$SUBMODULE' not found in .gitmodules."
    exit 1
fi

printf "You are about to permanently remove the submodule '%s'.\n" "$SUBMODULE"
printf "Are you sure you want to continue? [y/N]: "
read CONFIRM
case "$CONFIRM" in
[yY][eE][sS] | [yY]) ;;
*)
    echo "Aborted."
    exit 0
    ;;
esac

echo "Removing submodule: $SUBMODULE ..."

# Deinitialize the submodule (removes from .git/config, cleans worktree)
git submodule deinit -f "$SUBMODULE" || {
    echo "Failed to deinitialize submodule."
    exit 1
}

# Remove from the Git index and .gitmodules (stages both changes)
git rm -f "$SUBMODULE" || {
    echo "Failed to remove submodule from index."
    exit 1
}

# Remove the cached module data
MODULE_DIR=".git/modules/$SUBMODULE"
if [ -d "$MODULE_DIR" ]; then
    rm -rf "$MODULE_DIR"
fi

# Commit the changes
git commit -m "chore(submodule)!: remove $SUBMODULE submodule"

echo "Submodule '$SUBMODULE' removed successfully!"
